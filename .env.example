# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Email (Resend). REPORT_FROM_EMAIL must be a verified sender.
RESEND_API_KEY=
REPORT_FROM_EMAIL=reports@example.com

# Cron auth — required header to call /api/cron/tick
# Vercel Cron auto-sends "Authorization: Bearer $CRON_SECRET"
CRON_SECRET=

# Optional: shared password gate for the whole UI (leave blank to disable)
APP_PASSWORD=
