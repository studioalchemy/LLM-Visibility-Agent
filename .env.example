# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Email — Gmail API via OAuth2 refresh token (see README §1 Email)
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=
REPORT_FROM_EMAIL=          # the Gmail address that owns the refresh token

# Cron auth — only needed if you keep the Vercel cron path enabled.
# Railway-worker-only deployments can leave this blank.
CRON_SECRET=

# Optional: shared password gate for the whole UI (leave blank to disable)
APP_PASSWORD=
